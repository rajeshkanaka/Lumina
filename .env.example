# Lumina — Vertex AI only. No API keys.

# Backend (optional): URL of the Lumina Python backend. Default: http://localhost:8000
# VITE_API_URL=http://localhost:8000

# --- Vertex AI (backend only; set when running the backend) ---
# GOOGLE_GENAI_USE_VERTEXAI=1
# GOOGLE_CLOUD_LOCATION=global
# GOOGLE_CLOUD_PROJECT=adktalentpulse360
# Authenticate: gcloud auth application-default login

# APP_URL: optional, for deployment (e.g. Cloud Run).
# APP_URL=MY_APP_URL
